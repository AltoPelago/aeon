#!/bin/aeon --profile=ts.object.v1

//# Escaped decoded-identity rooted and chained clone stress
aeon:header = {
  version = "1.0"
  mode = "transport"
  profile = "ts.object.v1"
}

"aA":int32 = 1
rootClone = ~$.["a\u0041"]

obj = {
  "bA":int32 = 2
}
rootNested = ~$.obj.["b\u0041"]

host@{
  "xA":int32 = 3
} = 4
rootAttr = ~$.host@["x\u0041"]

chain1 = ~["a\u0041"]
chain2 = ~chain1

