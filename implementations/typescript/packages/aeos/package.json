{
  "name": "@aeos/core",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aeos-validator": "./dist/bin/aeos-validator.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --test-name-pattern='.*' dist/*.test.js dist/rules/*.test.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@aeon/aes": "workspace:*",
    "@aeon/lexer": "workspace:*"
  }
}
