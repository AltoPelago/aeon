{
  "name": "@aeon/finalize",
  "version": "0.9.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/*.test.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aeon/aes": "workspace:*"
  },
  "devDependencies": {
    "@aeon/parser": "workspace:*",
    "@aeon/lexer": "workspace:*"
  }
}
